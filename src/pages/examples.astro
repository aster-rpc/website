---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BrandMark from '../components/BrandMark.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout>
  <Header>
    <BrandMark slot="mark" />
  </Header>

  <main>
    <section class="section hero-section">
      <div class="shell surface-dark pad hero-card">
        <div>
          <div class="meta-label">Examples</div>
          <h1>Examples chosen to show why the model matters.</h1>
          <p>
            These are not generic demo apps. They are workload shapes where identity-first
            connectivity, portable contracts, or session-scoped interaction change the design.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell grid grid-2">
        <article class="card surface-light light-card">
          <div class="meta-label">Python first</div>
          <h2>Python service mesh without address-first assumptions</h2>
          <p>Expose Python services behind NAT using cryptographic identity and contract publication rather than fixed ingress infrastructure.</p>
        </article>
        <article class="card surface-light light-card">
          <div class="meta-label">Architecture example</div>
          <h2>Mixed topology control plane</h2>
          <p>Coordinate services across operator networks, relays, and moving nodes while preserving explicit trust boundaries.</p>
        </article>
        <article class="card surface-light light-card">
          <div class="meta-label">Row-mode example</div>
          <h2>Data-heavy transfer path</h2>
          <p>Use serialization modes appropriate for structured, high-volume payloads without flattening the rest of the service model.</p>
        </article>
        <article class="card surface-light light-card">
          <div class="meta-label">Session-scoped example</div>
          <h2>Long-lived typed interaction</h2>
          <p>Model agent or edge sessions as first-class streams instead of forcing everything into isolated request/response calls.</p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .pad { padding: 26px; }
  .hero-section { padding-top: 24px; }
  .hero-card h1 { margin: 0; font-size: clamp(38px, 6vw, 68px); line-height: 0.98; letter-spacing: -0.05em; color: var(--cloud-strong); max-width: 11ch; }
  .hero-card p { margin: 14px 0 0; max-width: 62ch; color: var(--mist); font-size: 16px; }
  .grid { display: grid; gap: 16px; }
  .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .card { border-radius: var(--radius-lg); padding: 22px; }
  .light-card { border: 1px solid rgba(25, 37, 51, 0.1); }
  .meta-label { margin-bottom: 10px; font-size: 11px; line-height: 1.2; letter-spacing: 0.12em; text-transform: uppercase; }
  .card h2 { margin: 0; color: var(--ink); font-size: 24px; line-height: 1.08; letter-spacing: -0.04em; }
  .card p { margin: 10px 0 0; color: var(--ink-soft); font-size: 14px; line-height: 1.55; }
  @media (max-width: 900px) {
    .grid-2 { grid-template-columns: 1fr; }
    .pad { padding: 22px; }
  }
</style>
