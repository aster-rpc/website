---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BrandMark from '../components/BrandMark.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout>
  <Header>
    <BrandMark slot="mark" />
  </Header>

  <main>
    <section class="section hero-section">
      <div class="shell surface-dark pad hero-card">
        <div>
          <div class="meta-label">About</div>
          <h1>Current status, direction, and where to go next.</h1>
          <p>
            Aster is a greenfield systems project. The current emphasis is Python-first
            implementation, specification clarity, and a path toward cross-runtime interoperability.
          </p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="shell grid grid-3">
        <article class="card surface-light light-card">
          <div class="meta-label">Status</div>
          <h2>Design phase, active implementation</h2>
          <p>The architecture and trust model are already coherent enough to explain publicly, while the ecosystem remains early.</p>
        </article>
        <article class="card surface-light light-card">
          <div class="meta-label">Today</div>
          <h2>Python first</h2>
          <p>Python is the exemplar implementation and the first place where the system surface is being proven in practice.</p>
        </article>
        <article class="card surface-light light-card">
          <div class="meta-label">Direction</div>
          <h2>Cross-runtime by design</h2>
          <p>Rust, JVM, .NET, Go, and JavaScript/TypeScript follow the shared protocol and conformance direction.</p>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="shell surface-dark pad link-card">
        <div>
          <div class="meta-label">Next stops</div>
          <h2>Read the spec. Check implementation status. Go to docs.</h2>
        </div>
        <div class="links">
          <a href="https://docs.aster.site">Docs</a>
          <a href="https://github.com/aster-rpc">GitHub</a>
          <a href="https://github.com/aster-rpc/spec">Specification</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .pad { padding: 26px; }
  .hero-section { padding-top: 24px; }
  .hero-card h1, .link-card h2 { margin: 0; letter-spacing: -0.05em; }
  .hero-card h1 { font-size: clamp(38px, 6vw, 68px); line-height: 0.98; color: var(--cloud-strong); max-width: 11ch; }
  .hero-card p { margin: 14px 0 0; max-width: 62ch; color: var(--mist); font-size: 16px; }
  .grid { display: grid; gap: 16px; }
  .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .card { border-radius: var(--radius-lg); padding: 22px; }
  .light-card { border: 1px solid rgba(25, 37, 51, 0.1); }
  .meta-label { margin-bottom: 10px; font-size: 11px; line-height: 1.2; letter-spacing: 0.12em; text-transform: uppercase; }
  .card h2, .link-card h2 { color: var(--ink); font-size: 24px; line-height: 1.08; }
  .card p { margin: 10px 0 0; color: var(--ink-soft); font-size: 14px; line-height: 1.55; }
  .link-card { display: grid; gap: 18px; }
  .link-card h2 { color: var(--cloud-strong); font-size: clamp(28px, 4vw, 44px); }
  .links { display: flex; flex-wrap: wrap; gap: 12px; }
  .links a { border-radius: 999px; padding: 12px 14px; border: 1px solid var(--border-dark); color: var(--cloud-strong); background: rgba(255,255,255,0.03); }
  @media (max-width: 900px) {
    .grid-3 { grid-template-columns: 1fr; }
    .pad { padding: 22px; }
  }
</style>
