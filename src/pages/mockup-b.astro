---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BrandMark from '../components/BrandMark.astro';
import WhyAsterMerged from '../components/WhyAsterMerged.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Aster — Two machines. One function call. No infrastructure."
  description="Your services are behind firewalls, NATs, and CGNATs. Aster connects them by cryptographic identity — no DNS, no certificates, no port forwarding."
>
  <Header>
    <BrandMark slot="mark" />
    <span slot="tagline" class="brand-tagline">P2P RPC Framework</span>
  </Header>

  <main>
    <WhyAsterMerged />
  </main>

  <Footer />

</BaseLayout>
