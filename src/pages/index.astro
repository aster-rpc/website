---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import BrandMark from '../components/BrandMark.astro';
import WhyAsterMerged from '../components/WhyAsterMerged.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Aster — P2P RPC Framework. No VPNs. No NAT gateways. No port forwarding."
  description="Connect your AI agents to your code - anywhere. Aster punches through firewalls, NATs, and CGNATs with cryptographic identity. No DNS, no certificates, no infrastructure."
>
  <Header>
    <BrandMark slot="mark" />
    <span slot="tagline" class="brand-tagline">P2P RPC Framework</span>
  </Header>

  <main>
    <WhyAsterMerged />
  </main>

  <Footer />

  <style is:global>
    html, body { overflow-x: hidden; }
  </style>
</BaseLayout>
