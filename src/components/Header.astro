---
const links = [
  { href: '/why', label: 'Why' },
  { href: '/architecture', label: 'Architecture' },
  { href: '/trust', label: 'Trust' },
  { href: '/examples', label: 'Examples' },
  { href: 'https://docs.aster.site', label: 'Docs' },
];
---
<header class="topbar">
  <div class="shell topbar-inner">
    <a class="brand" href="/">
      <slot name="mark" />
      <span>Aster</span>
    </a>
    <nav class="nav" aria-label="Primary">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
      <span class="status-chip"><i></i> 0.1-alpha · Python reference</span>
    </nav>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(18px);
    background: linear-gradient(180deg, rgba(11, 15, 20, 0.88), rgba(11, 15, 20, 0.62));
    border-bottom: 1px solid rgba(163, 178, 196, 0.08);
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 78px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-weight: 650;
    font-size: 18px;
    color: var(--cloud-strong);
    letter-spacing: -0.034em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    color: rgba(217, 225, 234, 0.88);
    font-size: 15px;
    font-weight: 540;
    letter-spacing: -0.018em;
  }
  .nav a {
    transition: color .18s ease, opacity .18s ease;
    opacity: 0.92;
  }
  .nav a:hover { color: var(--cloud-strong); opacity: 1; }
  .status-chip {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mist);
    padding: 10px 12px;
    border: 1px solid var(--border-dark);
    border-radius: 999px;
    background: rgba(17, 24, 33, 0.74);
    font-family: var(--mono);
  }
  .status-chip i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--relay);
    box-shadow: 0 0 0 6px rgba(97, 214, 194, 0.08);
    display: inline-block;
  }
  @media (max-width: 900px) {
    .topbar-inner { min-height: auto; padding: 14px 0; flex-direction: column; align-items: stretch; }
    .nav { justify-content: space-between; }
  }
</style>
