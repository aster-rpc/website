---
const links = [
  { href: '/blog', label: 'Blog' },
  { href: 'https://docs.aster.site', label: 'Docs' },
];
const githubUrl = 'https://github.com/aster-rpc/aster-rpc';
---
<header class="topbar">
  <div class="shell topbar-inner">
    <a class="brand" href="/">
      <slot name="mark" />
      <span>Aster</span>
      <slot name="tagline" />
    </a>
    <nav class="nav" aria-label="Primary">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
      <a href={githubUrl} aria-label="GitHub" class="nav-github">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(18px);
    background: linear-gradient(180deg, rgba(11, 15, 20, 0.88), rgba(11, 15, 20, 0.62));
    border-bottom: 1px solid rgba(163, 178, 196, 0.08);
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 78px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-weight: 650;
    font-size: 20px;
    color: var(--cloud-strong);
    letter-spacing: -0.034em;
  }
  .brand :global(.brand-tagline) {
    font-weight: 400;
    font-size: 14px;
    color: var(--mist-2);
    letter-spacing: -0.01em;
    opacity: 0.7;
    position: relative;
    top: 1px;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    color: rgba(217, 225, 234, 0.88);
    font-size: 15px;
    font-weight: 540;
    letter-spacing: -0.018em;
  }
  .nav a {
    transition: color .18s ease, opacity .18s ease;
    opacity: 0.92;
  }
  .nav a:hover { color: var(--cloud-strong); opacity: 1; }
  .status-chip {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mist);
    padding: 10px 12px;
    border: 1px solid var(--border-dark);
    border-radius: 999px;
    background: rgba(17, 24, 33, 0.74);
    font-family: var(--mono);
  }
  .status-chip i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--relay);
    box-shadow: 0 0 0 6px rgba(97, 214, 194, 0.08);
    display: inline-block;
  }
  .nav-github {
    display: flex;
    align-items: center;
    opacity: 0.72;
  }
  .nav-github:hover { opacity: 1; }

  @media (max-width: 900px) {
    .topbar-inner { min-height: 56px; gap: 16px; }
    .brand { font-size: 17px; gap: 10px; }
    .brand :global(.brand-tagline) { display: none; }
    .nav { gap: 18px; font-size: 14px; }
  }
</style>
