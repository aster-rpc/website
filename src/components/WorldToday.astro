---
import AsterNetworkMap from './AsterNetworkMap.astro';

const blockers = [
  {
    label: 'Firewalls',
    copy: 'Great for protection, awkward when the code you own needs to accept a call.',
  },
  {
    label: 'CGNATs',
    copy: 'Starlink, home broadband, mobile networks, and office Wi-Fi can hide the machine completely.',
  },
  {
    label: 'Proxies',
    copy: 'Useful until every tool call depends on another hosted service, secret, or policy surface.',
  },
  {
    label: 'TLS certificates',
    copy: 'Aster does not need hostnames and certificates just to prove which machine answered.',
  },
];

const useCases = [
  'An AI agent needs to call tools running on your laptop, homelab, or customer site.',
  'A fleet service needs to reach devices and edge workers without port forwarding.',
  'Two services in different clouds need typed RPC without building a mesh first.',
];
---

<section class="world-section" aria-labelledby="world-title">
  <div class="shell world-grid">
    <div class="world-copy">
      <span class="meta-label">The moment Aster makes sense</span>
      <h2 id="world-title">Your code is reachable. The network says otherwise.</h2>
      <p>
        Today&apos;s default answer is to expose something: a hostname, a load
        balancer, a tunnel, a proxy, a certificate chain, a pile of shared
        secrets. Aster takes the shorter path: machines dial each other by
        cryptographic identity and the transport handles the messy route.
      </p>

      <div class="use-when" aria-label="Use Aster when">
        <strong>Use Aster when:</strong>
        <ul>
          {useCases.map((useCase) => <li>{useCase}</li>)}
        </ul>
      </div>
    </div>

    <figure class="world-figure">
      <div class="world-map-wrap">
        <AsterNetworkMap />
      </div>
      <figcaption>
        Aster lets the call cross the network you actually have, not the one
        your architecture diagram wished for.
      </figcaption>
    </figure>
  </div>

  <div class="shell blocker-grid" aria-label="Obstacles Aster removes">
    {blockers.map((blocker) => (
      <div class="blocker">
        <span>{blocker.label}</span>
        <p>{blocker.copy}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .world-section {
    position: relative;
    padding: clamp(54px, 8vw, 110px) 0 clamp(48px, 7vw, 94px);
    overflow: hidden;
  }

  .world-section::before {
    content: "";
    position: absolute;
    inset: 12% -10vw auto;
    height: 24rem;
    background:
      linear-gradient(90deg, rgba(97, 214, 194, 0.07) 1px, transparent 1px),
      linear-gradient(rgba(97, 214, 194, 0.07) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse at 34% 50%, #000 0%, transparent 68%);
    pointer-events: none;
  }

  .world-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(18rem, 0.86fr) minmax(0, 1.14fr);
    gap: clamp(30px, 5vw, 70px);
    align-items: center;
  }

  .world-copy {
    max-width: 38rem;
  }

  .world-copy h2 {
    margin: 12px 0 0;
    max-width: 11ch;
    color: var(--cloud-strong);
    font-size: clamp(44px, 6.6vw, 82px);
    line-height: 0.92;
    letter-spacing: -0.07em;
    text-wrap: balance;
  }

  .world-copy p {
    margin: 24px 0 0;
    color: var(--cloud);
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.46;
    letter-spacing: -0.024em;
  }

  .use-when {
    margin-top: 28px;
    padding-left: 18px;
    border-left: 2px solid rgba(97, 214, 194, 0.48);
  }

  .use-when strong {
    display: block;
    color: var(--relay);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .use-when ul {
    display: grid;
    gap: 10px;
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
  }

  .use-when li {
    color: var(--mist);
    font-size: 16px;
    line-height: 1.55;
  }

  .world-figure {
    position: relative;
    margin: 0;
    border: 1px solid rgba(163, 178, 196, 0.11);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(17, 24, 33, 0.82), rgba(10, 15, 21, 0.92)),
      radial-gradient(circle at 70% 18%, rgba(120, 166, 255, 0.16), transparent 34%);
    box-shadow: var(--shadow-dark);
    overflow: hidden;
  }

  .world-map-wrap {
    width: 100%;
    overflow: auto hidden;
  }

  .world-figure figcaption {
    margin: 0;
    padding: 16px 18px 18px;
    color: var(--mist);
    font-size: 14px;
    line-height: 1.5;
    border-top: 1px solid rgba(163, 178, 196, 0.1);
  }

  .blocker-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: clamp(26px, 4vw, 44px);
  }

  .blocker {
    min-height: 156px;
    padding: 18px;
    border: 1px solid rgba(163, 178, 196, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.028);
  }

  .blocker span {
    color: var(--cloud-strong);
    font-size: 20px;
    font-weight: 680;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .blocker p {
    margin: 10px 0 0;
    color: var(--mist);
    font-size: 14px;
    line-height: 1.55;
  }

  @media (max-width: 960px) {
    .world-grid,
    .blocker-grid {
      grid-template-columns: 1fr;
    }

    .world-copy h2 {
      max-width: 12ch;
    }

    .blocker {
      min-height: 0;
    }
  }

</style>
