---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="shell footer-card">
    <div class="footer-copy">
      <strong>Aster</strong>
      <p>Identity-first distributed systems substrate. iroh QUIC transport, Apache Fory serialization, and language-native service definitions across Python and TypeScript alpha bindings.</p>
    </div>
    <div class="footer-meta">
      <span class="badge">aster-rpc</span>
      <span class="badge">0.1-alpha</span>
      <span class="badge">Python + TypeScript</span>
      <span class="badge">Apache 2.0</span>
    </div>
  </div>
  <p class="footer-copyright">Copyright © {year} Emrul Islam. All rights reserved.</p>
</footer>

<style>
  .footer { padding: 34px 0 70px; }
  .footer-card {
    border-radius: 28px;
    border: 1px solid var(--border-dark);
    background: linear-gradient(180deg, rgba(18, 25, 35, 0.92), rgba(12, 18, 26, 0.96));
    box-shadow: var(--shadow-dark);
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-copy { max-width: 58ch; }
  .footer-copy strong {
    display: block; font-size: 24px; line-height: 1.05; letter-spacing: -0.04em;
    color: var(--cloud-strong); margin-bottom: 8px;
  }
  .footer-copy p { margin: 0; color: var(--mist); font-size: 15px; }
  .footer-meta { display: flex; gap: 10px; flex-wrap: wrap; }
  .footer-copyright {
    width: min(calc(100% - 32px), var(--max));
    margin: 16px auto 0;
    color: rgba(165, 179, 194, 0.68);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .badge {
    font-size: 11px; letter-spacing: .05em; color: var(--cloud); border: 1px solid rgba(163,178,196,0.1);
    border-radius: 999px; padding: 7px 10px; background: rgba(255,255,255,0.03);
  }
</style>
